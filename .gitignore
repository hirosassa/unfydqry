# =============================================================================
# unimose - cross-platform search engine (Rust core + iOS + Android)
# =============================================================================

# -----------------------------------------------------------------------------
# OS / Editor noise
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Rust (core/)
# -----------------------------------------------------------------------------
target/
**/*.rs.bk
*.pdb

# Bindings + headers generated from the Rust core via uniffi-bindgen.
# Regenerated reproducibly from the Rust source; sample apps copy them in.
core/generated/

# -----------------------------------------------------------------------------
# iOS / SwiftPM
#   Package.swift lives at repo root, iOS sources / tests / xcframework under ios/
# -----------------------------------------------------------------------------

# XCFramework build artifact (re-creatable via xcodebuild -create-xcframework)
ios/UniversalQuery.xcframework/

# SwiftPM build / resolution artifacts (root from Package.swift)
/.build/
/Package.resolved
/.swiftpm/
# Some xcodebuild flows materialize these inside ios/ as well
ios/.build/
ios/.swiftpm/

# Intermediate xcframework slice scratch space
ios/build/

# Sample app: xcodeproj is generated by xcodegen from project.yml
ios/sample/SearchSample.xcodeproj/
ios/sample/build/

# Info.plist is generated by xcodegen from project.yml
ios/sample/SearchSample/Info.plist

# Xcode noise (in case project files get committed for any sub-tree)
xcuserdata/
*.xcuserstate
*.xcuserdatad/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
Pods/

# Swift Package Manager
.swiftpm/
.build/

# -----------------------------------------------------------------------------
# Android (android/)
# -----------------------------------------------------------------------------

# .so artifacts copied from cargo-ndk output (re-creatable)
android/jniLibs/
android/sample/app/src/main/jniLibs/

# Kotlin binding for :searchcore module is committed (mirror of iOS Sources/SearchCore/),
# so the module is consumable without the Rust toolchain. Do NOT ignore it.

# Gradle / AGP outputs
android/sample/.gradle/
android/sample/build/
android/sample/*/build/
android/sample/local.properties
android/sample/captures/
android/sample/.cxx/

# Android Studio noise
*.iml
android/sample/.idea/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
.env
.env.local
